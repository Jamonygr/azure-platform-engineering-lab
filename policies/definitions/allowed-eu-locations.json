{
  "$schema": "https://schema.management.azure.com/schemas/2019-09-01/policyDefinition.json#",
  "properties": {
    "displayName": "Platform environments use approved EU regions",
    "description": "Restricts regional resources to the platform's tested EU allowlist while permitting global resources.",
    "policyType": "Custom",
    "mode": "All",
    "metadata": {
      "category": "Platform Engineering",
      "version": "1.0.0"
    },
    "parameters": {
      "allowedLocations": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed locations",
          "strongType": "location"
        },
        "defaultValue": [
          "westeurope",
          "northeurope",
          "germanywestcentral"
        ]
      },
      "effect": {
        "type": "String",
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "location",
            "exists": "true"
          },
          {
            "field": "location",
            "notEquals": "global"
          },
          {
            "field": "location",
            "notIn": "[parameters('allowedLocations')]"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
