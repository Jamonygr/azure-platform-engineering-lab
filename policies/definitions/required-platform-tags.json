{
  "$schema": "https://schema.management.azure.com/schemas/2019-09-01/policyDefinition.json#",
  "properties": {
    "displayName": "Platform environments must carry lifecycle tags",
    "description": "Audits or denies indexed resources that omit the immutable environment, owner, or expiration tags used by the lifecycle controller.",
    "policyType": "Custom",
    "mode": "Indexed",
    "metadata": {
      "category": "Platform Engineering",
      "version": "1.0.0"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "field": "tags['platform.environment_id']",
            "exists": "false"
          },
          {
            "field": "tags['platform.owner']",
            "exists": "false"
          },
          {
            "field": "tags['platform.expires_at']",
            "exists": "false"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
