root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{tf,hcl}]
indent_style = space
indent_size = 2

[*.{yml,yaml,json,md,ts,js}]
indent_style = space
indent_size = 2

[*.ps1]
end_of_line = crlf
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
